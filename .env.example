# FarmConnect AI — environment configuration.
# Copy this file to ".env" and fill in the blanks. NEVER commit the real .env.
# In development, config.py loads this automatically via python-dotenv.

# ---- Flask -----------------------------------------------------------------
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ---- Supabase --------------------------------------------------------------
# Project: farmconnect-ai
SUPABASE_URL=https://hmncndwzowymvzfhxzqk.supabase.co
# Publishable ("anon") key — safe in the browser, protected by Row Level Security.
SUPABASE_ANON_KEY=sb_publishable_vUQNDOJ3FRCw5AuOTvRo7A_Zpm9jia-
# Service-role (secret) key — SERVER ONLY. Get it from:
#   Supabase Dashboard > farmconnect-ai > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string for the app's data layer (users, listings, messages,
# community, ratings). Dashboard > Project Settings > Database > Connection string
# (URI). Use the "Session pooler" or "Transaction pooler" string and put your DB
# password in it. Example:
#   postgresql://postgres.hmncndwzowymvzfhxzqk:YOUR-DB-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# ---- Hugging Face ----------------------------------------------------------
# Create a token at https://huggingface.co/settings/tokens (read access is enough).
HF_TOKEN=
# Serverless instruct model that writes the answers.
HF_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
# Embedding model. Its dimension MUST match the kb_chunks.embedding vector size
# (all-MiniLM-L6-v2 = 384). If you change this, re-create the column + re-ingest.
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_PROVIDER=hf-inference

# ---- Backends --------------------------------------------------------------
# Retrieval: "supabase" (cloud pgvector + HF embeddings) or "local" (offline engine).
FARMCONNECT_RAG_BACKEND=supabase
# Answer model: "hf" (Hugging Face), "cloud" (Claude), "local" (Ollama), or "auto".
FARMCONNECT_LLM_BACKEND=hf
